# 8 核 CPU / 16 GB 内存 / SSD；可选 6 GB 以上 NVIDIA 显存。
HARDWARE_PROFILE=recommended
OLLAMA_NUM_PARALLEL=4
SEARCH_MAX_CONCURRENCY=12
SEARCH_QUEUE_TIMEOUT_MS=2000
SEARCH_TOTAL_TIMEOUT_MS=10000
SEARCH_VECTOR_TIMEOUT_MS=7000
SEARCH_KEYWORD_TIMEOUT_MS=3000
SEARCH_STRUCTURE_TIMEOUT_MS=2000
SEARCH_NEIGHBOR_TIMEOUT_MS=1000
SEARCH_ENRICH_TIMEOUT_MS=1500
SEARCH_CONTEXT_MAX_CHARS=2000
GRAPH_RETRIEVAL_ENABLED=true
GRAPH_RETRIEVAL_TIMEOUT_MS=800
GRAPH_RETRIEVAL_WEIGHT=0.35
GRAPH_RETRIEVAL_MAX_RESULTS=3
GRAPH_RETRIEVAL_MAX_HOPS=2
GRAPH_RETRIEVAL_SEED_COUNT=3
GRAPH_RETRIEVAL_MIN_EDGE_WEIGHT=0.25
EMBEDDING_MAX_CONNECTIONS=24
EMBEDDING_MAX_KEEPALIVE_CONNECTIONS=8
EMBEDDING_MAX_BATCH_SIZE=200
