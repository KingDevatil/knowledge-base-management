# 4 核 CPU / 8 GB 内存 / SSD；无独显或低配开发机。
HARDWARE_PROFILE=minimum
OLLAMA_NUM_PARALLEL=1
SEARCH_MAX_CONCURRENCY=4
SEARCH_QUEUE_TIMEOUT_MS=1500
SEARCH_TOTAL_TIMEOUT_MS=15000
SEARCH_VECTOR_TIMEOUT_MS=10000
SEARCH_KEYWORD_TIMEOUT_MS=5000
SEARCH_STRUCTURE_TIMEOUT_MS=3000
SEARCH_NEIGHBOR_TIMEOUT_MS=2000
SEARCH_ENRICH_TIMEOUT_MS=2500
SEARCH_CONTEXT_MAX_CHARS=1200
GRAPH_RETRIEVAL_ENABLED=true
GRAPH_RETRIEVAL_TIMEOUT_MS=600
GRAPH_RETRIEVAL_WEIGHT=0.30
GRAPH_RETRIEVAL_MAX_RESULTS=2
GRAPH_RETRIEVAL_MAX_HOPS=1
GRAPH_RETRIEVAL_SEED_COUNT=2
GRAPH_RETRIEVAL_MIN_EDGE_WEIGHT=0.30
EMBEDDING_MAX_CONNECTIONS=8
EMBEDDING_MAX_KEEPALIVE_CONNECTIONS=4
EMBEDDING_MAX_BATCH_SIZE=64
