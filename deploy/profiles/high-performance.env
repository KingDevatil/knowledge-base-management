# 12 核以上 CPU / 32 GB 内存 / NVMe；建议 12 GB 以上 NVIDIA 显存。
HARDWARE_PROFILE=high-performance
OLLAMA_NUM_PARALLEL=8
SEARCH_MAX_CONCURRENCY=20
SEARCH_QUEUE_TIMEOUT_MS=2000
SEARCH_TOTAL_TIMEOUT_MS=8000
SEARCH_VECTOR_TIMEOUT_MS=5000
SEARCH_KEYWORD_TIMEOUT_MS=2000
SEARCH_STRUCTURE_TIMEOUT_MS=1500
SEARCH_NEIGHBOR_TIMEOUT_MS=800
SEARCH_ENRICH_TIMEOUT_MS=1200
SEARCH_CONTEXT_MAX_CHARS=3000
GRAPH_RETRIEVAL_ENABLED=true
GRAPH_RETRIEVAL_TIMEOUT_MS=1000
GRAPH_RETRIEVAL_WEIGHT=0.40
GRAPH_RETRIEVAL_MAX_RESULTS=5
GRAPH_RETRIEVAL_MAX_HOPS=2
GRAPH_RETRIEVAL_SEED_COUNT=5
GRAPH_RETRIEVAL_MIN_EDGE_WEIGHT=0.20
EMBEDDING_MAX_CONNECTIONS=40
EMBEDDING_MAX_KEEPALIVE_CONNECTIONS=20
EMBEDDING_MAX_BATCH_SIZE=300
