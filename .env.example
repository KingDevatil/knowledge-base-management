# ==================== 服务配置 ====================
APP_NAME=Company KB MCP Gateway
DEBUG=false

# ==================== Redis ====================
REDIS_URL=redis://redis:6379/0

# ==================== Chroma ====================
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=company_kb

# ==================== Ollama ====================
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=bge-m3

# ==================== MinIO ====================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-strong-password
MINIO_BUCKET=kb-sources
MINIO_SECURE=false

# ==================== 认证配置 ====================
SESSION_SECRET=change-me-to-a-random-long-string-at-least-32-chars
SESSION_MAX_AGE=86400

# ==================== 切片配置 ====================
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ==================== 锁配置 ====================
WRITE_LOCK_KEY=kb:write_lock
WRITE_LOCK_TTL=30

# ==================== 限流配置 ====================
RATE_LIMIT_DEFAULT=30

# ==================== CORS 配置 ====================
# 如需跨域调用 API，请设置为允许的域名，逗号分隔
# 例如：CORS_ORIGINS=https://app.company.com,https://admin.company.com
CORS_ORIGINS=*
