# ==================== 基础配置 ====================
APP_NAME=Knowledge Base Management
DEBUG=false

# ==================== 数据存储路径 ====================
# 全局数据目录。所有运行时数据（配置、Chroma 向量、MinIO 对象存储）
# 都放在此目录下。设置后配置文件的路径会自动派生。
#
# Docker 部署: 可留空，使用 Docker 原生路径
# Windows 开发: 设置为项目根目录下的 kbdata（由 start-dev.ps1 自动设置）
# 自定义路径: D:/kb-data
#KBDATA_DIR=

# ==================== 域名配置（部署用） ====================
# 外网域名（用于 HTTPS 和 CORS）
EXTERNAL_DOMAIN=kb.company.com
# 内网域名或 IP（用于局域网 HTTP 访问）
INTERNAL_DOMAIN=kb.internal.company.com
# 外网/内网监听 IP（默认 0.0.0.0 监听所有网卡）
EXTERNAL_IP=0.0.0.0
INTERNAL_IP=0.0.0.0

# ==================== CORS ====================
# 逗号分隔，允许跨域访问的来源
# 部署时建议明确指定域名，开发环境可保留 *
CORS_ORIGINS=*

# ==================== Redis ====================
REDIS_URL=redis://redis:6379/0

# ==================== Chroma ====================
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=knowledge_base_management

# ==================== Ollama ====================
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=bge-m3

# ==================== MinIO ====================
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_SECRET_KEY=change-me-strong-password
MINIO_BUCKET=kb-sources
MINIO_SECURE=false

# ==================== 认证配置 ====================
SESSION_SECRET=change-me-to-a-random-long-string-at-least-32-chars
SESSION_MAX_AGE=86400

# ==================== 切片配置 ====================
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ==================== 锁配置 ====================
WRITE_LOCK_KEY=kb:write_lock
WRITE_LOCK_TTL=30

# ==================== 限流配置 ====================
RATE_LIMIT_DEFAULT=30
