# ==================== 基础配置 ====================
APP_NAME=Knowledge Base Management
DEBUG=false

# ==================== 数据存储路径 ====================
# 全局数据目录。所有运行时数据（配置、Chroma 向量、MinIO 对象存储）
# 都放在此目录下。设置后配置文件的路径会自动派生。
#
# Docker 部署: 使用 HOST_KBDATA_DIR 指定宿主机数据目录，容器内固定为 /app/data
# 本地开发: 推荐 ./kbdata 或 kbdata，避免把某台机器的绝对路径写死到通用配置
# 自定义路径: Linux 可用 /data/kb-data，Windows 本机开发可用 D:/kb-data
#KBDATA_DIR=
HOST_KBDATA_DIR=./kbdata

# ==================== 域名配置（部署用） ====================
# 外网域名（用于 HTTPS 和 CORS）
EXTERNAL_DOMAIN=kb.company.com
# 内网域名或 IP（用于局域网 HTTP 访问）
INTERNAL_DOMAIN=kb.internal.company.com
# 外网/内网监听 IP（默认 0.0.0.0 监听所有网卡）
# 仅用于 Docker compose Nginx 端口绑定，Gateway 本身不读取此变量
EXTERNAL_IP=0.0.0.0
INTERNAL_IP=0.0.0.0

# ==================== 内置反向代理 ====================
# true 时 Docker Nginx 会按当前后台反代方案代理 80/443；false 时不代理到应用。
REVERSE_PROXY_ENABLED=true
# 以下运行变量通常由后台“反向代理”设置页自动写入 kbdata/config/service.env。
# 手动部署时也可直接填写。
#REVERSE_PROXY_DOMAIN=kb.example.com
#REVERSE_PROXY_UPSTREAM_HOST=mcp-gateway
#REVERSE_PROXY_UPSTREAM_PORT=8000
#REVERSE_PROXY_SSL_CERT_FILE=/etc/nginx/ssl/kb.example.com/fullchain.pem
#REVERSE_PROXY_SSL_KEY_FILE=/etc/nginx/ssl/kb.example.com/privkey.pem
#REVERSE_PROXY_FORCE_HTTPS=true

# ==================== CORS ====================
# 逗号分隔，允许跨域访问的来源
# 部署时建议明确指定域名，开发环境可保留 *
CORS_ORIGINS=*

# ==================== 服务监听 ====================
# Gateway 监听地址。Docker 部署由 compose 管理，此值不生效。
# 本地开发如需局域网访问可设为 0.0.0.0（配合防火墙使用）。
#BIND_HOST=0.0.0.0

# ==================== Redis ====================
# Docker 环境使用服务名 redis；本地开发请改为 localhost
REDIS_URL=redis://redis:6379/0

# ==================== Chroma ====================
# Docker 环境使用服务名 chroma；本地开发请改为 localhost
CHROMA_HOST=chroma
# Docker 内部端口为 8000（compose 映射到宿主机 8001）
# 本地开发时若 Chroma 在 Docker 中请设为 8001，本地安装请设为 8000
CHROMA_PORT=8000
CHROMA_COLLECTION=knowledge_base_management

# ==================== Ollama ====================
# Docker 环境使用服务名 ollama；本地开发请改为 localhost
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=bge-m3
# Ollama 容器并发请求数（传给 Ollama 容器，Gateway 不读取）
# GPU 显存充足可调高，CPU-only 建议设为 1
OLLAMA_NUM_PARALLEL=4

# ==================== MinIO ====================
# Docker 环境使用服务名 minio；本地开发请改为 localhost
MINIO_ENDPOINT=minio:9000
# MinIO 容器管理用户名（Docker compose 下自动映射为 MINIO_ACCESS_KEY 传给 Gateway）
# 本地开发请直接使用下方的 MINIO_ACCESS_KEY
MINIO_ROOT_USER=minioadmin
# MinIO 容器管理密码（Docker compose 下自动映射为 MINIO_SECRET_KEY 传给 Gateway）
MINIO_ROOT_PASSWORD=change-me-strong-password
# Gateway 连接 MinIO 的 Access Key（非 Docker 时直接生效）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-strong-password
MINIO_BUCKET=kb-sources
MINIO_SECURE=false

# ==================== 认证配置 ====================
SESSION_SECRET=change-me-to-a-random-long-string-at-least-32-chars
SESSION_MAX_AGE=86400
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=123456

# ==================== 切片配置 ====================
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ==================== 国内镜像加速（国内部署用） ====================
# Docker Hub 镜像前缀。国内部署设为 docker.m.daocloud.io/ 可大幅加速镜像拉取
# 所有公共镜像（nginx/redis/chroma/minio/ollama/python）都会加上此前缀
#MIRROR_PREFIX=docker.m.daocloud.io/

# pip 镜像源地址
#PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
#PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

# apt 镜像源地址（用于 Dockerfile 中 apt-get 加速）
#APT_MIRROR=mirrors.tuna.tsinghua.edu.cn
WRITE_LOCK_KEY=kb:write_lock
WRITE_LOCK_TTL=30

# ==================== 限流配置 ====================
RATE_LIMIT_DEFAULT=30
