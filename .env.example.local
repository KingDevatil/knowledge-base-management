# ==================== 本地开发环境配置 ====================
# start-dev.ps1 会自动把此文件复制为 .env.local 并加载。
# Docker 使用根目录 .env，两套配置互不覆盖。
# 所有服务地址均为 localhost，适合本地开发场景。
# 如需 Docker 部署请参考 .env.example。

# ==================== 基础配置 ====================
APP_NAME=Knowledge Base Management (Dev)
DEBUG=true
HARDWARE_PROFILE=recommended

# Windows 原生启动器优先通过 winget 自动安装 Python、Ollama、Memurai。
# winget 不可用时，Python 会按清华镜像 -> Python.org 顺序下载，Ollama 使用官方安装器；
# Memurai 会按下方固定版本的官方 MSI 安装。可用 -NoAutoInstall 禁止系统依赖安装。
PYTHON_BOOTSTRAP_VERSION=3.13.14
MEMURAI_BOOTSTRAP_VERSION=4.1.2
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
PIP_FALLBACK_INDEX_URL=https://pypi.org/simple
PIP_FALLBACK_TRUSTED_HOST=pypi.org

# ==================== 数据存储路径 ====================
# 本地开发建议使用项目相对路径，Linux、Docker 和 Windows 都可复用。
# 如果使用启动器，它会自动使用项目根目录下的 kbdata，无需在此设置。
#KBDATA_DIR=./kbdata

# ==================== 域名配置 ====================
# 本地开发域名/IP，部分功能（如分享链接生成）可能用到
EXTERNAL_DOMAIN=localhost
INTERNAL_DOMAIN=localhost

# ==================== CORS ====================
# 开发环境允许所有来源
CORS_ORIGINS=*

# ==================== 服务监听 ====================
# Gateway 监听地址。0.0.0.0 允许局域网其他设备通过 IP/mDNS 访问。
# 仅本地访问请改为 127.0.0.1。
BIND_HOST=0.0.0.0

# ==================== Redis ====================
# Windows PowerShell 5.1 对 localhost 的 IPv6 回退可能超时，原生依赖固定使用 IPv4 环回。
REDIS_URL=redis://127.0.0.1:6379/0

# ==================== 检索配置 ====================
SEARCH_CACHE_TTL=300
SEARCH_TOTAL_TIMEOUT_MS=10000
SEARCH_ENRICH_TIMEOUT_MS=1500
SEARCH_VECTOR_TIMEOUT_MS=7000
SEARCH_KEYWORD_TIMEOUT_MS=3000
SEARCH_STRUCTURE_TIMEOUT_MS=2000
SEARCH_NEIGHBOR_TIMEOUT_MS=1000
SEARCH_MAX_CONCURRENCY=12
SEARCH_QUEUE_TIMEOUT_MS=2000
SEARCH_CONTEXT_MAX_CHARS=2000

# 图谱关联检索：图谱未构建时自动跳过，不影响普通搜索。
GRAPH_RETRIEVAL_ENABLED=true
GRAPH_RETRIEVAL_TIMEOUT_MS=800
GRAPH_RETRIEVAL_WEIGHT=0.35
GRAPH_RETRIEVAL_MAX_RESULTS=3
GRAPH_RETRIEVAL_MAX_HOPS=2
GRAPH_RETRIEVAL_SEED_COUNT=3
GRAPH_RETRIEVAL_MIN_EDGE_WEIGHT=0.25

# ==================== Chroma ====================
# 原生启动器让 Chroma 监听本机 8001；Docker 部署使用独立的 .env。
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8001
CHROMA_COLLECTION=knowledge_base_management

# ==================== Ollama ====================
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=bge-m3
OLLAMA_NUM_PARALLEL=4

# Embedding HTTP 连接池与单批文本数
EMBEDDING_REQUEST_TIMEOUT_SECONDS=120
EMBEDDING_HEALTH_TIMEOUT_SECONDS=5
EMBEDDING_MAX_CONNECTIONS=24
EMBEDDING_MAX_KEEPALIVE_CONNECTIONS=8
EMBEDDING_MAX_BATCH_SIZE=200

# ==================== MinIO ====================
MINIO_ENDPOINT=127.0.0.1:9000
# 本地开发直接使用 MINIO_ACCESS_KEY（无需 MINIO_ROOT_USER）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kb-sources
MINIO_SECURE=false

# ==================== 认证配置 ====================
# DEBUG=true 时不会校验 SESSION_SECRET 长度，可设简单值便于开发
SESSION_SECRET=dev-secret-key-not-for-production
SESSION_MAX_AGE=86400

# ==================== 切片配置 ====================
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ==================== 锁配置 ====================
WRITE_LOCK_KEY=kb:write_lock
WRITE_LOCK_TTL=30

# ==================== 限流配置 ====================
RATE_LIMIT_DEFAULT=30
