# ==================== 本地开发环境配置 ====================
# 将此文件复制为 .env 后使用（不要直接编辑本文件）：
#   copy .env.example.local .env
# 所有服务地址均为 localhost，适合本地开发场景。
# 如需 Docker 部署请参考 .env.example。

# ==================== 基础配置 ====================
APP_NAME=Knowledge Base Management (Dev)
DEBUG=true

# ==================== 数据存储路径 ====================
# 本地开发建议设置为项目根目录下的 kbdata。
# 如果使用启动器，它会自动注入绝对路径，无需在此设置。
# 如需设置，请用绝对路径（如 D:/kbdata），避免相对路径因 CWD 不同导致错位。
#KBDATA_DIR=D:/kimicode/knowledge-base-management/kbdata

# ==================== 域名配置 ====================
# 本地开发域名/IP，部分功能（如分享链接生成）可能用到
EXTERNAL_DOMAIN=localhost
INTERNAL_DOMAIN=localhost

# ==================== CORS ====================
# 开发环境允许所有来源
CORS_ORIGINS=*

# ==================== 服务监听 ====================
# Gateway 监听地址。0.0.0.0 允许局域网其他设备通过 IP/mDNS 访问。
# 仅本地访问请改为 127.0.0.1。
BIND_HOST=0.0.0.0

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0

# ==================== Chroma ====================
# 如果 Chroma 通过 Docker 运行（compose 映射 8001→8000），设为 8001
# 如果 Chroma 本地安装直接运行，保持 8000
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=knowledge_base_management

# ==================== Ollama ====================
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=bge-m3

# ==================== MinIO ====================
MINIO_ENDPOINT=localhost:9000
# 本地开发直接使用 MINIO_ACCESS_KEY（无需 MINIO_ROOT_USER）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kb-sources
MINIO_SECURE=false

# ==================== 认证配置 ====================
# DEBUG=true 时不会校验 SESSION_SECRET 长度，可设简单值便于开发
SESSION_SECRET=dev-secret-key-not-for-production
SESSION_MAX_AGE=86400

# ==================== 切片配置 ====================
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ==================== 锁配置 ====================
WRITE_LOCK_KEY=kb:write_lock
WRITE_LOCK_TTL=30

# ==================== 限流配置 ====================
RATE_LIMIT_DEFAULT=30
