#!/bin/sh
# KNOWBASE_CLI_WRAPPER=1

set -u

CONFIG_DIR=${XDG_CONFIG_HOME:-"$HOME/.config"}/knowbase
HOME_FILE="$CONFIG_DIR/home"
if [ ! -f "$HOME_FILE" ]; then
    echo "[错误] Knowbase CLI 配置不存在。请在项目目录运行 sh ./start.sh cli-install。" >&2
    exit 1
fi
KNOWBASE_HOME=$(sed -n '1p' "$HOME_FILE")
if [ -z "$KNOWBASE_HOME" ] || [ ! -f "$KNOWBASE_HOME/scripts/knowbase.sh" ]; then
    echo "[错误] Knowbase 项目已移动或删除：$KNOWBASE_HOME" >&2
    echo "       请在新的项目目录重新运行 sh ./start.sh cli-install。" >&2
    exit 1
fi
exec sh "$KNOWBASE_HOME/scripts/knowbase.sh" "$@"
